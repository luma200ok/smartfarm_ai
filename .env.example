# Phase 3 — LLM (Ollama 로컬). 실제 값은 .env 로 복사(.env 는 .gitignore).
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=bge-m3          # RAG 임베딩 모델 (ollama pull bge-m3)

# Phase 3-4 — 디스코드 알림 (기존 smartfarm 웹훅 URL 기입, 없으면 알림 비활성)
DISCORD_WEBHOOK_URL=

# PostgreSQL + pgvector — RAG 저장소·처방/경보 이력 (선택, 미설정 시 현행 npz+무이력 그대로)
RAG_BACKEND=memory          # memory(기본) | pgvector
DATABASE_URL=               # 예: postgresql://smartfarm:비밀번호@localhost:5432/smartfarm
# ⚠️ env 변경(RAG_BACKEND·DATABASE_URL)은 프로세스 재시작 후 반영됨(런타임 재적용 안 됨).
